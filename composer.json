{
    "name": "psc-acme/processor-catalog",
    "description": "Package processor-catalog for psc-acme organization",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Philipp Scheit",
            "email": "p.scheit@packagist.com"
        }
    ],
    "autoload": {
        "psr-4": {
            "PscAcme\\ProcessorCatalog\\": "src/"
        }
    },
    "require": {
        "php": ">=8.1",
        "predis/predis": "^2.0",
        "carbon/carbon": "^3.0",
        "laravel/framework": "^11.0"
    },
    "require-dev": {
        "webforge/object-asserter": "^2.0.0",
        "phpstan/phpstan": "^1.0"
    },
    "minimum-stability": "stable",
    "config": {
        "secure-http": false
    },
    "repositories": {
        "private-packagist": {
            "type": "composer",
            "url": "http://repo.packagist.com.lo/psc-acme/"
        },
        "packagist.org": false
    }
}